generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

// Defines user access levels across the system
enum Role {
  VIEWER
  ANALYST
  ADMIN
}

// Represents lifecycle state of a user account
enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Type of financial record
enum RecordType {
  INCOME
  EXPENSE
}

//////////////////////
// USER MODEL
//////////////////////

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  email       String   @unique
  password    String
  name        String?

  role        Role     @default(VIEWER)
  status      Status   @default(ACTIVE)

  lastLoginAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  records     Record[]

  // Indexes for filtering/admin queries
  @@index([role])
  @@index([status])
}

//////////////////////
// FINANCIAL RECORD
//////////////////////

model Record {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  amount      Float
  type        RecordType
  category    String
  date        DateTime

  notes       String?

  // Soft delete (used instead of hard delete to preserve financial history)
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Ownership
  createdBy   String   @db.ObjectId
  createdUser User     @relation(fields: [createdBy], references: [id])

  //////////////////////
  // INDEXES (IMPORTANT)
  //////////////////////

  // Basic filters
  @@index([type])
  @@index([category])
  @@index([date])
  @@index([createdBy])

  // Frequently used in queries (VERY IMPORTANT)
  @@index([isDeleted])
  @@index([type, date])
  @@index([category, date])
}

//////////////////////
// AUDIT LOG
//////////////////////

// Tracks system actions for debugging, traceability, and security auditing
model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  userId      String?  @db.ObjectId

  action      String   // e.g. CREATE_RECORD, UPDATE_USER
  entity      String   // e.g. "Record", "User"
  entityId    String?  // affected entity ID

  metadata    Json?    // flexible payload for debugging / traceability

  createdAt   DateTime @default(now())

  // Indexes for audit queries
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}